extends ../../layout

block content
  .artists.px-4
    .d-flex.justify-content-between.mt-4
      h2.title #{t('guess_page.popularArtist')}
    ul.d-flex.mt-3.pl-0
      each author in authors
        li.item(role="button")
          img.avatar.circle(src=author.avatar, alt=author.fullname)
          a.full_name(href="#") #{author.fullname}
          p.artist #{t('guess_page.artist')}
  
